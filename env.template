# ==================== 模型配置 ====================

# 模型提供商选择 (deepseek, doubao 或 auto)
# - deepseek: 仅使用DeepSeek
# - doubao: 仅使用豆包
# - auto: 智能选择（根据题目自动选择最合适的模型）
MODEL_PROVIDER=auto

# ==================== 智能模型选择配置 ====================
# 仅在 MODEL_PROVIDER=auto 时生效

# 是否启用智能选择（建议开启）
AUTO_MODEL_SELECTION=true

# 纯文本题目首选模型（成本更低、速度更快）
PREFER_MODEL=deepseek

# 图片题目使用的模型（豆包支持多模态）
IMAGE_MODEL=doubao

# ==================== DeepSeek配置 ====================
# 获取API密钥: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
# 模型选择: deepseek-chat (普通模式) 或 deepseek-reasoner (思考模式)
# 注意：如果ENABLE_REASONING=true，会自动使用deepseek-reasoner
DEEPSEEK_MODEL=deepseek-chat

# ==================== 豆包配置 ====================
# 获取API密钥: https://console.volcengine.com/ark
DOUBAO_API_KEY=
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# 豆包推理接入点ID（在豆包控制台创建）
# 注意：实际使用模型已在 custom_models.json 中定义，此字段仅为旧版兼容保留
DOUBAO_MODEL=doubao-seed-1-6-251015

# ==================== 智谱GLM配置 ====================
# 获取API密钥: https://bigmodel.cn/usercenter/proj-mgmt/apikeys
# GLM-4.6V-Flash 是免费的图像理解模型，作为识图首选模型
# 若高峰期失败会自动降级到其他模型
GLM_API_KEY=

# ==================== 通义千问Qwen配置 ====================
# 获取API密钥: https://help.aliyun.com/zh/model-studio/getting-started/get-api-key
# DashScope API Key（阿里百炼平台）
# Qwen VL Flash 是轻量级视觉模型，Qwen3.7-Plus 是更强力的视觉推理模型
# QWEN_BASE_URL 请使用您的百炼工作空间专属地址
DASHSCOPE_API_KEY=
QWEN_BASE_URL=
# 模型名（可按需覆盖）
QWEN_VL_FLASH_MODEL=qwen-vl-flash
QWEN_3_7_PLUS_MODEL=qwen3.7-plus

# ==================== 思考模式 ====================
# 是否启用推理模式（全局设置）
# DeepSeek: 启用后自动使用deepseek-reasoner模型
# 豆包: 启用后会添加reasoning_effort参数
ENABLE_REASONING=false
# 思考强度: low, medium, high (仅豆包)
REASONING_EFFORT=medium
# 多选题自动启用深度思考（true/false）
AUTO_REASONING_FOR_MULTIPLE=true
# 带图片题目自动启用深度思考（true/false）
AUTO_REASONING_FOR_IMAGES=true

# ==================== AI参数 ====================

# 温度参数 (0.0-2.0)
# 控制答案的随机性和创造性
# - 0.0-0.3: 确定性高，适合答题（推荐答题使用0.1）
# - 0.4-0.7: 平衡模式，适合对话
# - 0.8-2.0: 创造性高，但答案可能不准确
TEMPERATURE=0.1

# 最大输出token数 (1-8192)
# 限制AI回复的最大长度（普通模式）
# - 填空题: 200-300 足够
# - 选择题: 300-500 合适
# - 复杂题目: 可增加到 1000+
# 注意：deepseek-chat 最大支持 8192
MAX_TOKENS=500

# 思考模式的最大输出token数 (1-65536)
# 思考模式需要更大的token来进行深度推理
# - 简单思考: 2000-4000
# - 中等复杂: 4096-8000（推荐）
# - 复杂推理: 8000-16000
# - 极端复杂: 16000-65536
# 注意：deepseek-reasoner 最大支持 65536
REASONING_MAX_TOKENS=4096

# Top-p核采样参数 (0.0-1.0)
# 控制词汇选择范围，影响表达的多样性
# - 0.9-1.0: 词汇丰富，表达自然（推荐0.95）
# - 0.5-0.8: 更保守，重复性增加
# - 0.1-0.4: 非常保守，可能过于机械
TOP_P=0.95

# ==================== 本地OCR配置 ====================
# PP-OCRv6 本地 OCR，免费优先于云端视觉模型
# 文字图片：OCR提取达标则直接文字答题，不调用任何云端模型
# 复杂图片：OCR失败或检测到公式/图表时进入云端视觉链
ENABLE_LOCAL_OCR=false
# OCR达标最低字符数
OCR_TEXT_MIN_CHARS=12
# OCR最低平均置信度 (0.0-1.0)
OCR_MIN_CONFIDENCE=0.75
# OCR最低有效文本行数
OCR_MIN_LINES=2
# OCR CPU 线程数（默认 2，降低对后台其他程序的影响，设为 0 则用 Paddle 默认值）
OCR_CPU_THREADS=2

# ==================== GLM熔断配置 ====================
# GLM 返回 429/超时/5xx 后的熔断时间（秒）
# 熔断期间跳过 GLM，直接使用下一模型
GLM_CIRCUIT_BREAK_SECONDS=300

# ==================== 网络配置 ====================
# HTTP代理（可选，如需要代理访问API）
HTTP_PROXY=
# HTTPS代理（可选）
HTTPS_PROXY=
# 请求超时时间（秒）
TIMEOUT=180.0
# 最大重试次数
MAX_RETRIES=3

# ==================== 服务配置 ====================
HOST=0.0.0.0
PORT=5000
DEBUG=False
# 日志级别: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ==================== 安全配置 ====================
# 访问密钥文件路径（首次启动自动生成）
SECRET_KEY_FILE=.secret_key
# 连续错误尝试次数限制（防暴力破解）
RATE_LIMIT_ATTEMPTS=5
# 限流时间窗口（秒）- 错误次数达到上限后的冷却时间
RATE_LIMIT_WINDOW=300

# ==================== CSV日志配置 ====================
# CSV日志文件路径（相对路径或绝对路径）
# 默认: ocs_answers_log.csv
CSV_LOG_FILE=ocs_answers_log.csv
