[
  {
    "name": "AI智能答题",
    "url": "http://localhost:5000/api/answer",
    "method": "post",
    "type": "fetch",
    "contentType": "json",
    "homepage": "https://github.com/zhuzhangxue/ocs-ai-answerer",
    "headers": {
      "Content-Type": "application/json"
    },
    "data": {
      "question": "${title}",
      "options": "${options}",
      "type": "${type}",
      "images": []
    },
    "handler": "return (res)=>{if(res.ocs_format_multi)return res.ocs_format_multi;return res.success&&res.ocs_format?[res.ocs_format]:[];}"
  }
]
